// SendYurt data model.
// Local dev runs on SQLite; the schema deliberately avoids SQLite-only or
// Postgres-only constructs so switching `provider` to "postgresql" for
// deployment requires no model changes. Enums are not supported by SQLite,
// so role/status/type fields are strings constrained by zod at the app
// boundary (see src/lib/validators.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Investor / pilot inquiries submitted from the public pitch page.
model InvestorInquiry {
  id           String   @id @default(cuid())
  name         String
  email        String
  organization String?
  // "INVESTOR" | "PILOT" — which CTA the inquiry came from
  kind         String   @default("INVESTOR")
  message      String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())
  // Household-level settings surfaced on the Household Settings page.
  currency          String  @default("UZS")
  privacyMode       Boolean @default(false)
  trustScoreSharing Boolean @default(true)

  users        User[]
  transactions Transaction[]
  budgets      Budget[]
  savingsGoals SavingsGoal[]
  trustScores  TrustScoreSnapshot[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // "SENDER" | "RECEIVER" — validated in app code (SQLite has no enums)
  role         String
  name         String
  // Profile picture as a small downscaled data URL (no external storage).
  image        String?
  languagePref String   @default("uz")
  householdId  String
  // Permission inside the household: "ADMIN" (edit budgets/goals, manage
  // roles) | "VIEWER" (read-only). Distinct from `role`, which is the
  // family position (sender/receiver). Everyone defaults to ADMIN;
  // admins may restrict others to VIEWER.
  accessRole   String    @default("ADMIN")
  // Saved "usual" transfer for one-tap rate comparisons.
  usualSendAmount   Decimal?
  usualSendCurrency String?
  // Set when the user finishes (or skips) the first-run walkthrough.
  onboardedAt  DateTime?
  createdAt    DateTime @default(now())

  household        Household     @relation(fields: [householdId], references: [id])
  sentTransactions Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  passwordResetTokens PasswordResetToken[]
  notifications    Notification[]
}

model Notification {
  id          String    @id @default(cuid())
  // Fanned out per member so each person has their own read state.
  userId      String
  householdId String
  // "REMITTANCE_LOGGED" | "GOAL_NEAR" | "SCORE_CHANGE"
  type        String
  // JSON with the values needed to render the message in any language,
  // e.g. {"goal":"Toʻy fund","percent":85} — text is localized at render.
  payload     String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model PasswordResetToken {
  id String @id @default(cuid())
  userId String
  // sha256 of the raw token — the raw value only ever lives in the email link
  tokenHash String @unique
  expiresAt DateTime
  usedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RemittanceProvider {
  id                 String  @id @default(cuid())
  name               String
  slug               String  @unique
  // Flat fee charged in the source currency
  baseFee            Decimal @default(0)
  // Percentage fee on the send amount, e.g. 1.5 means 1.5%
  percentFee         Decimal @default(0)
  // Margin the provider takes off the mid-market rate, e.g. 2.0 means 2%
  exchangeRateMargin Decimal @default(0)
  transferSpeedHours Int     @default(24)
  // Comma-separated ISO codes of supported source currencies, e.g. "USD,RUB,KZT"
  sourceCurrencies   String

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  householdId String
  // "REMITTANCE" (money sent home) | "EXPENSE" | "INCOME" | "SAVINGS"
  type        String
  // Nullable: only remittances have sender/receiver/provider
  senderId    String?
  receiverId  String?
  providerId  String?
  // Nullable: set on SAVINGS rows that contribute to a specific goal, so the
  // goal-detail view can show real contributors and contribution history.
  goalId      String?
  amount      Decimal
  currency    String   @default("UZS")
  // For remittances: the original send-side amount and currency
  sourceAmount   Decimal?
  sourceCurrency String?
  // Budget category slug for EXPENSE rows (see src/lib/categories.ts)
  category    String?
  note        String?
  date        DateTime
  // "PENDING" | "COMPLETED" | "FAILED"
  status      String   @default("COMPLETED")
  // True for rows created by the seed script (demo history is labeled in the UI)
  isDemo      Boolean  @default(false)
  createdAt   DateTime @default(now())

  household Household           @relation(fields: [householdId], references: [id])
  sender    User?               @relation("SentTransactions", fields: [senderId], references: [id])
  receiver  User?               @relation("ReceivedTransactions", fields: [receiverId], references: [id])
  provider  RemittanceProvider? @relation(fields: [providerId], references: [id])
  goal      SavingsGoal?        @relation(fields: [goalId], references: [id])

  @@index([householdId, date])
  @@index([householdId, type])
  @@index([goalId])
}

model Budget {
  id              String  @id @default(cuid())
  householdId     String
  category        String
  amountAllocated Decimal
  // Month the allocation applies to, formatted "YYYY-MM"
  period          String

  household Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, category, period])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  householdId   String
  name          String
  targetAmount  Decimal
  currentAmount Decimal   @default(0)
  targetDate    DateTime?
  createdAt     DateTime  @default(now())

  household     Household     @relation(fields: [householdId], references: [id])
  contributions Transaction[]
}

model TrustScoreSnapshot {
  id                String   @id @default(cuid())
  householdId       String
  score             Int
  consistencyFactor Int
  stabilityFactor   Int
  savingsFactor     Int
  calculatedAt      DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])

  @@index([householdId, calculatedAt])
}
