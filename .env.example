# Copy to .env and fill in. Never commit real secrets.

# SQLite for local development:
DATABASE_URL="file:./dev.db"
# Hosted Postgres (Neon/Supabase) for production — also switch the
# datasource provider in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Absolute URL of the deployment (http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
