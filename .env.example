# Copy to .env and fill in. Never commit real secrets.

# SQLite for local development:
DATABASE_URL="file:./dev.db"
# Hosted Postgres (Neon/Supabase) for production — also switch the
# datasource provider in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Absolute URL of the deployment (http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Optional — powers the in-app AI assistant (Yordam) with Claude.
# Without a key the assistant runs in built-in guide mode.
# Get a key at https://platform.claude.com
# ANTHROPIC_API_KEY=""
# ASSISTANT_MODEL="claude-opus-4-8"

# Optional — live FX rates for the rate finder (exchangerate-api.com).
# Leave unset to use the provider's free keyless endpoint (open.er-api.com);
# set a key to use the authenticated v6 endpoint. Falls back to the static
# sample table when the feed is unreachable.
# EXCHANGERATE_API_KEY=""

# Supabase — auth (email/password) + wallet/transaction system.
# Find these in your Supabase project: Settings > API. The publishable
# (anon) key is safe to expose to the browser. REQUIRED on Vercel for
# production auth to work.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
